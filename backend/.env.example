# .env.example

# バックエンド環境変数 (Backend Environment Variables)

# Neonプロジェクトの接続詳細から取得します。
# 例: DATABASE_URL="postgresql://user:password@host:port/dbname"
DATABASE_URL=

# OpenRouter APIキー
OPENROUTER_API_KEY=

# OpenRouter AIモデル
OPENROUTER_AI_MODEL=

# AI リトライ設定（省略時はデフォルト値使用）
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY=1.0
AI_RETRY_MAX_DELAY=10.0
AI_TIMEOUT=30.0