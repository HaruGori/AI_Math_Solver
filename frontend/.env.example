# .env.example

# フロントエンド環境変数 (Frontend Environment Variables)

# NextAuthのURL (例: http://localhost:3000 または デプロイされたURL)
NEXTAUTH_URL=

# NextAuthのシークレット (openssl rand -base64 32 で生成可能)
NEXTAUTH_SECRET=

# Vercel Blobの読み書きトークン
NEXT_PUBLIC_BLOB_READ_WRITE_TOKEN=

# Google OAuth クライアントID (Auth.jsで使用する場合)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google OAuth クライアントシークレット (Auth.jsで使用する場合)
GOOGLE_CLIENT_SECRET=
